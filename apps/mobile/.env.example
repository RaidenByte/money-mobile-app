# Production (Render) API URL - recommended default
EXPO_PUBLIC_API_URL=https://money-mobile-api.onrender.com

# Local backend examples (uncomment when needed):
# Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# Physical Android phone (same Wi-Fi): EXPO_PUBLIC_API_URL=http://<your-computer-lan-ip>:3000
# iOS simulator / web: EXPO_PUBLIC_API_URL=http://localhost:3000
