{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android:onekey": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android.ps1 -SkipInstall",
    "android:expo-go": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android.ps1 -UseExpoGo -SkipInstall",
    "eas:init": "eas init --id",
    "eas:configure": "eas build:configure",
    "eas:apk": "eas build -p android --profile preview",
    "eas:aab": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "expo": "~54.0.33",
    "expo-file-system": "~19.0.21",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^18.6.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
